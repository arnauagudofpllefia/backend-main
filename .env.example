# Puerto del servidor
PORT=3000

# MongoDB Atlas Connection String
# Reemplaza <username>, <password> y <cluster> con tus credenciales
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/alumnos?retryWrites=true&w=majority

# URL del frontend para CORS (opcional, para desarrollo local)
FRONTEND_URL=http://localhost:5173

